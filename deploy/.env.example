# Copy to .env.local and fill in values
# These are passed to the OpenClaw container via deploy.sh
# NOTE: This file is auto-generated from templates/env.example — edit the template instead.

# --- LLM Providers ---
# The starter config uses ChatGPT Plus (Codex) as primary with Alibaba Coding Plan fallbacks.
# Codex uses OAuth (no API key needed) — set up after deploy via:
#   docker compose exec openclaw-gateway openclaw models auth login --provider openai-codex
# See docs/account-setup.md section 6 for details.

# Alibaba Coding Plan (fallbacks + heartbeats — sign up at alibabacloud.com/product/model-studio)
ALIBABA_CODING_API_KEY=...

# Optional: additional providers (add matching config to deploy/openclaw.json)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_CREDITS_API_KEY=sk-ant-...
# FIREWORKS_API_KEY=...

# --- Channels ---

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=...

# Twitter/X developer app credentials (from https://console.x.com)
# Used by scripts/twitter-oauth.py to generate access tokens
# X_CONSUMER_KEY=...
# X_CONSUMER_SECRET=...

# --- GitHub ---

# Personal access token (repo scope) for your agent's GitHub account
AGENT_GITHUB_PAT=ghp_...

# --- Infrastructure ---

# Hetzner Cloud API token (for Terraform, local only — not pushed to server)
HETZNER_API_KEY=...

# --- Deploy Config ---

# Path to SSH key for server access (default: ~/.ssh/agent_ed25519)
# AGENT_SSH_KEY=$HOME/.ssh/agent_ed25519

# Server IP override (default: auto-resolved from infra/terraform.tfstate)
# AGENT_SERVER_IP=
