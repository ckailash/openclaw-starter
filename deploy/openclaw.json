{
  "models": {
    "mode": "merge",
    "providers": {
      "alibaba": {
        "baseUrl": "https://coding-intl.dashscope.aliyuncs.com/v1",
        "apiKey": "${ALIBABA_CODING_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 256000,
            "maxTokens": 8192
          },
          {
            "id": "glm-4.7",
            "name": "GLM-4.7",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 202752,
            "maxTokens": 8192
          },
          {
            "id": "qwen3.5-plus",
            "name": "Qwen 3.5 Plus",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.3-codex",
        "fallbacks": [
          "openai-codex/gpt-5.1-codex-mini",
          "alibaba/kimi-k2.5",
          "alibaba/qwen3.5-plus",
          "alibaba/glm-4.7"
        ]
      },
      "heartbeat": {
        "every": "30m",
        "model": "alibaba/glm-4.7",
        "target": "last",
        "ackMaxChars": 300
      },
      "subagents": {
        "model": "openai-codex/gpt-5.1-codex-mini",
        "maxConcurrent": 4,
        "archiveAfterMinutes": 60
      },
      "contextTokens": 200000
    }
  },

  "gateway": {
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    }
  },

  "browser": {
    "enabled": true
  }
}
